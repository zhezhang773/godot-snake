# Godot 4 .gitignore

# Godot-specific ignores
.import/
export.cfg
export_presets.cfg

# Imported translations (automatically generated from CSV files)
*.translation

# Mono-specific ignores
.mono/
data_*/
mono_crash.*.json

# Build directories
bin/
obj/

# System/tool-specific ignores
.directory
*~
.DS_Store
Thumbs.db

# Godot editor settings
.editor_settings-4.tres

# User-specific files
user://
